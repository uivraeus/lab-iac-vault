# Copy to local/oidc.env and fill in values from your IdP app registration.
# This file is sourced by env.sh when present.
export TF_VAR_enable_oidc=true
export TF_VAR_oidc_discovery_url="https://login.microsoftonline.com/<tenant-id>/v2.0"
export TF_VAR_oidc_client_id="<client-id>"
export TF_VAR_oidc_client_secret="<client-secret>"
